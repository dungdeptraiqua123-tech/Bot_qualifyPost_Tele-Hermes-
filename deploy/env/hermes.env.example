# Hermes runtime env. This file is copied to /opt/hermes-ads/hermes.env on VPS.
# Do not commit the real /opt/hermes-ads/hermes.env file.

HERMES_HOME=/opt/hermes-ads/hermes-home

# OpenAI-compatible API server exposed by `hermes gateway`.
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8642
API_SERVER_MODEL_NAME=hermes-agent
API_SERVER_KEY=

# Main model used by Hermes. DeepSeek is the default path for this project.
HERMES_PROVIDER=deepseek
HERMES_PROVIDER_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=

# Optional provider keys if you switch Hermes later.
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

PYTHONUNBUFFERED=1
