# Telegram worker bot env. This file is copied to /opt/hermes-ads/bot.env on VPS.
# Do not commit the real /opt/hermes-ads/bot.env file.

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=@Goldenn123bot
ADMIN_USER_IDS=

# Optional seed only. After startup, manage source channels in Telegram with:
# /allow_add, /allow_remove, /allow_list
ALLOWED_CHANNEL_IDS=

DROP_PENDING_UPDATES=false
LOG_LEVEL=INFO

TELEGRAM_REQUEST_TIMEOUT_SECONDS=30
TELEGRAM_POLLING_TIMEOUT_SECONDS=30
TELEGRAM_POLLING_READ_TIMEOUT_SECONDS=45
TELEGRAM_MEDIA_GROUP_FLUSH_DELAY_SECONDS=2

REVIEW_ENABLED=true
REWRITE_ENABLED=true
PUBLISH_ENABLED=true

HERMES_API_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=
HERMES_REQUEST_TIMEOUT_SECONDS=120
REVIEW_SKILL_PATH=../skill-md/content-review.SKILL.md
REWRITE_SKILL_PATH=../skill-md/twitter-create-post.SKILL.md
