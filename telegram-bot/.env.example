TELEGRAM_BOT_TOKEN=put-your-token-here
TELEGRAM_BOT_USERNAME=@Goldenn123bot

# Optional seed for config/allowed_channels.json. After startup, manage source
# channels with /allow_add, /allow_remove, /allow_list.
# Leave empty to accept every channel while testing.
# Example: -1001234567890,-1009876543210
ALLOWED_CHANNEL_IDS=

# Required: comma-separated Telegram user IDs allowed to use bot commands.
ADMIN_USER_IDS=

DROP_PENDING_UPDATES=false
LOG_LEVEL=INFO

# Telegram network timeout tuning.
TELEGRAM_REQUEST_TIMEOUT_SECONDS=30
TELEGRAM_POLLING_TIMEOUT_SECONDS=30
TELEGRAM_POLLING_READ_TIMEOUT_SECONDS=45
TELEGRAM_MEDIA_GROUP_FLUSH_DELAY_SECONDS=2

# Persistent FIFO queue. Completed jobs are removed automatically.
POST_QUEUE_PATH=config/post_queue.json
POST_QUEUE_MAX_ATTEMPTS=3
POST_QUEUE_RETRY_DELAY_SECONDS=10
POST_QUEUE_POLL_INTERVAL_SECONDS=1

# Hermes Review Agent.
# For local testing, HERMES_API_KEY must match API_SERVER_KEY in %USERPROFILE%\.hermes\.env.
REVIEW_ENABLED=true
HERMES_API_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_REQUEST_TIMEOUT_SECONDS=120
REVIEW_SKILL_PATH=../skill-md/content-review.SKILL.md
REWRITE_ENABLED=true
REWRITE_SKILL_PATH=../skill-md/twitter-create-post.SKILL.md
PUBLISH_ENABLED=true
